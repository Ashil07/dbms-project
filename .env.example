# Copy this file to .env and fill in your values
# Never commit .env — it is gitignored

# ─── Database (NeonDB PostgreSQL) ────────────────────────────────────────────
# Use the POOLER connection string for serverless/Vercel deployments
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# ─── Cloudinary (image uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# ─── Server (local dev only — Vercel sets PORT automatically) ────────────────
PORT=3000

# ─── CORS (optional) ─────────────────────────────────────────────────────────
# Set this in Vercel if you use a custom domain (e.g. https://myapp.com).
# Leave empty on Vercel if you only use *.vercel.app — it's allowed by default.
# CLIENT_URL=https://your-custom-domain.com
