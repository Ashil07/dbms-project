{
    "name": "cloth-rental-system",
    "version": "1.0.0",
    "description": "Full-stack Cloth Rental System with Node.js, Express, Prisma, and Cloudinary",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "dev:client": "cd client && npm run dev",
        "dev:all": "concurrently \"npm run dev\" \"npm run dev:client\"",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "bcrypt": "^5.1.1",
        "cloudinary": "^2.2.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.3",
        "multer": "^1.4.5-lts.1",
        "prisma": "^5.22.0",
        "streamifier": "^0.1.1"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "nodemon": "^3.1.0"
    }
}
